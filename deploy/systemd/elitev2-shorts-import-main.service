[Unit]
Description=Sort dropped files in the elite-v2 main shorts import folder
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
User=thomas
Group=thomas
# Same script as the 18+ importer, but IMPORT_CHANNEL=main targets
# main/_import. Files are moved into profile folders as imported shorts;
# plain originals come in 'pending' for the transcoder.
ExecStart=/usr/bin/docker exec -e IMPORT_CHANNEL=main elitev2 node scripts/import-shorts.mjs
Nice=18
IOSchedulingClass=idle
