[Unit]
Description=Sort dropped images in the elite-v2 posts import folder
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
User=thomas
Group=thomas
# Runs inside the container (shares /posts-store + better-sqlite3 + sharp).
# Files in posts/_import are transcoded into creator folders as imported posts.
ExecStart=/usr/bin/docker exec elitev2 node scripts/import-posts.mjs
Nice=18
IOSchedulingClass=idle
